# Server configuration
PORT=5000
NODE_ENV=development

# Supabase Database configuration (Supabase connection string or credentials)
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
DB_USER=postgres
DB_HOST=db.[project-id].supabase.co
DB_DATABASE=postgres
DB_PASSWORD=your_database_password
DB_PORT=5432

# JWT Secret Configuration
JWT_ACCESS_SECRET=your_super_secret_access_token_key_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_54321
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Nodemailer Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
EMAIL_FROM=BuildConnect <noreply@buildconnect.com>
